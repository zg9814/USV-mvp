{
  "name": "usv-cloud-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --host 0.0.0.0 --port 5173 client",
    "simulate": "tsx server/src/simulate-usv.ts",
    "build": "npm-run-all build:server build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build client",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^5.4.19",
    "vue": "^3.5.16",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
